{
  "$schema": "https://champiq.dev/manifest/v2.json",
  "manifest_version": 2,
  "tool_id": "champmail",
  "name": "Champmail",
  "description": "Cold email sequences, reply detection, analytics.",
  "category": "outreach",
  "color": "#6366F1",
  "icon": "mail",
  "credentials_required": ["champmail"],
  "actions": [
    {
      "id": "add_prospect",
      "label": "Add Prospect",
      "input_schema": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {"type": "string", "format": "email"},
          "first_name": {"type": "string"},
          "last_name": {"type": "string"},
          "company": {"type": "string"},
          "title": {"type": "string"}
        }
      }
    },
    {
      "id": "start_sequence",
      "label": "Start Sequence",
      "input_schema": {
        "type": "object",
        "required": ["prospect_email", "sequence_id"],
        "properties": {
          "prospect_email": {"type": "string", "format": "email"},
          "sequence_id": {"type": "string"},
          "variables": {"type": "object"}
        }
      }
    },
    {
      "id": "pause_sequence",
      "label": "Pause Sequence",
      "input_schema": {
        "type": "object",
        "required": ["sequence_id"],
        "properties": {"sequence_id": {"type": "string"}}
      }
    },
    {
      "id": "send_single_email",
      "label": "Send One-Off Email",
      "input_schema": {
        "type": "object",
        "required": ["to", "subject", "body"],
        "properties": {
          "to": {"type": "string", "format": "email"},
          "subject": {"type": "string"},
          "body": {"type": "string"}
        }
      }
    },
    {
      "id": "get_analytics",
      "label": "Get Sequence Analytics",
      "input_schema": {
        "type": "object",
        "required": ["sequence_id"],
        "properties": {"sequence_id": {"type": "string"}}
      }
    }
  ],
  "triggers": [
    {"kind": "event", "event": "email.replied", "label": "On Email Replied"},
    {"kind": "event", "event": "email.opened", "label": "On Email Opened"},
    {"kind": "event", "event": "email.clicked", "label": "On Email Clicked"},
    {"kind": "event", "event": "email.bounced", "label": "On Email Bounced"},
    {"kind": "event", "event": "sequence.completed", "label": "On Sequence Completed"}
  ]
}
