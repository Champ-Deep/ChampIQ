{
  "$schema": "https://champiq.dev/manifest/v2.json",
  "manifest_version": 2,
  "tool_id": "champgraph",
  "name": "ChampGraph",
  "description": "Semantic knowledge graph — prospect/company relationships, NL queries.",
  "category": "data",
  "color": "#10B981",
  "icon": "graph",
  "credentials_required": ["champgraph"],
  "actions": [
    {
      "id": "get_prospect_status",
      "label": "Get Prospect Status",
      "description": "Fetch a prospect's current engagement status. Returns engagement_status: cold | sent | opened | replied | sequence_active | sequence_completed | not_found. Use a Switch node on {{ prev.data.engagement_status }} to route to mail engine or calling agent.",
      "input_schema": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {"type": "string", "format": "email"}
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "found":              {"type": "boolean"},
          "engagement_status":  {"type": "string", "enum": ["cold", "sent", "opened", "replied", "sequence_active", "sequence_completed", "not_found"]},
          "email_sent":         {"type": "boolean"},
          "email_opened":       {"type": "boolean"},
          "email_replied":      {"type": "boolean"},
          "sequence_active":    {"type": "boolean"},
          "sequence_completed": {"type": "boolean"}
        }
      }
    },
    {
      "id": "ingest_prospect",
      "label": "Ingest Prospect",
      "input_schema": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {"type": "string"},
          "name": {"type": "string"},
          "company": {"type": "string"},
          "title": {"type": "string"},
          "attributes": {"type": "object"}
        }
      }
    },
    {
      "id": "ingest_company",
      "label": "Ingest Company",
      "input_schema": {
        "type": "object",
        "required": ["domain"],
        "properties": {
          "domain": {"type": "string"},
          "name": {"type": "string"},
          "industry": {"type": "string"},
          "size": {"type": "string"}
        }
      }
    },
    {
      "id": "semantic_search",
      "label": "Semantic Search",
      "input_schema": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {"type": "string"},
          "limit": {"type": "integer", "default": 20}
        }
      }
    },
    {
      "id": "nl_query",
      "label": "NL Query",
      "input_schema": {
        "type": "object",
        "required": ["question"],
        "properties": {"question": {"type": "string"}}
      }
    },
    {
      "id": "add_relationship",
      "label": "Add Relationship",
      "input_schema": {
        "type": "object",
        "required": ["from_id", "to_id", "type"],
        "properties": {
          "from_id": {"type": "string"},
          "to_id": {"type": "string"},
          "type": {"type": "string"}
        }
      }
    }
  ],
  "triggers": []
}
