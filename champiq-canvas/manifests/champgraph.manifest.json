{
  "$schema": "https://champiq.dev/manifest/v2.json",
  "manifest_version": 2,
  "tool_id": "champgraph",
  "name": "ChampGraph",
  "description": "Semantic knowledge graph — prospect/company relationships, NL queries.",
  "category": "data",
  "color": "#10B981",
  "icon": "graph",
  "credentials_required": ["champgraph"],
  "actions": [
    {
      "id": "ingest_prospect",
      "label": "Ingest Prospect",
      "input_schema": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {"type": "string"},
          "name": {"type": "string"},
          "company": {"type": "string"},
          "title": {"type": "string"},
          "attributes": {"type": "object"}
        }
      }
    },
    {
      "id": "ingest_company",
      "label": "Ingest Company",
      "input_schema": {
        "type": "object",
        "required": ["domain"],
        "properties": {
          "domain": {"type": "string"},
          "name": {"type": "string"},
          "industry": {"type": "string"},
          "size": {"type": "string"}
        }
      }
    },
    {
      "id": "semantic_search",
      "label": "Semantic Search",
      "input_schema": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {"type": "string"},
          "limit": {"type": "integer", "default": 20}
        }
      }
    },
    {
      "id": "nl_query",
      "label": "NL Query",
      "input_schema": {
        "type": "object",
        "required": ["question"],
        "properties": {"question": {"type": "string"}}
      }
    },
    {
      "id": "add_relationship",
      "label": "Add Relationship",
      "input_schema": {
        "type": "object",
        "required": ["from_id", "to_id", "type"],
        "properties": {
          "from_id": {"type": "string"},
          "to_id": {"type": "string"},
          "type": {"type": "string"}
        }
      }
    }
  ],
  "triggers": []
}
