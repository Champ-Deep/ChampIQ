{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "services": {
    "api": {
      "source": "apps/api",
      "dockerfile": "apps/api/Dockerfile",
      "healthcheckPath": "/health",
      "variables": {
        "PORT": "8000",
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}"
      }
    },
    "web": {
      "source": "apps/web",
      "dockerfile": "apps/web/Dockerfile",
      "variables": {
        "VITE_API_URL": "${{api.RAILWAY_PUBLIC_DOMAIN}}"
      }
    }
  }
}
