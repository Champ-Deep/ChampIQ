# ─────────────────────────────────────────────────────────────────────────────
# ChampIQ Canvas — environment variable reference
# Copy to .env for local dev. On Railway, set these in the Variables panel.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Railway Postgres plugin sets this automatically) ────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/champiq

# ── Redis (Railway Redis plugin sets this automatically) ─────────────────────
# Must use rediss:// (TLS) for Railway Redis, or redis:// for local.
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── OpenRouter (LLM) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_REFERRER=https://champiq.app
OPENROUTER_APP_TITLE=ChampIQ Canvas

# ── ChampMail / ChampServer backend ──────────────────────────────────────────
CHAMPMAIL_BASE_URL=http://10.10.21.19:8000
CHAMPGRAPH_BASE_URL=http://10.10.21.19:8000
LAKEB2B_BASE_URL=http://10.10.21.19:8002

# ChampServer admin login (used by champmail + champgraph drivers to get JWT)
CHAMPSERVER_EMAIL=admin@champions.dev
CHAMPSERVER_PASSWORD=

# ── Optional CORS (comma-separated list of extra allowed origins) ─────────────
# Leave blank — Railway origins are auto-allowed via regex.
CORS_ORIGINS=
