# ChampIQ Voice Gateway — environment overrides
# Primary config lives in ~/.champiq/config.json (set via `champiq-voice config set`)
# These env vars can override config file values in Docker/Railway deployments.

# Redis (Railway sets REDIS_URL automatically when you add a Redis plugin)
REDIS_URL=redis://localhost:6379

# Config file location override (default: ~/.champiq/config.json)
# CHAMPIQ_CONFIG=/config/config.json

# Gateway port
PORT=3001

# Public URL of this gateway as seen from the internet.
# Set this on Railway to your Railway service URL, e.g.:
#   PUBLIC_GATEWAY_URL=https://champiq-voice.up.railway.app
# The frontend will display  <PUBLIC_GATEWAY_URL>/v1/webhook  as the
# ElevenLabs post-call webhook URL to paste into your agent settings.
# If unset, the gateway derives it from the inbound request Host header.
PUBLIC_GATEWAY_URL=
